@startuml Domain

title Ayvalık Bank HA-1 — Domain Layer\ndev.kaldiroglu.hexagonal.ayvalikbank.domain

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho

skinparam class {
    BackgroundColor White
    BorderColor #555
    ArrowColor #333
    FontSize 11
}
skinparam stereotype {
    CBackgroundColor<<entity>>    #DDEEFF
    CBorderColor<<entity>>        #3366AA
    CBackgroundColor<<record>>    #EEFFDD
    CBorderColor<<record>>        #336633
    CBackgroundColor<<service>>   #FFF5CC
    CBorderColor<<service>>       #AA8800
    CBackgroundColor<<sealed>>    #FFE0CC
    CBorderColor<<sealed>>        #AA5522
    CBackgroundColor<<state>>     #F0E0FF
    CBorderColor<<state>>         #663399
}

' ─────────────────────────────────────────
' PACKAGE: domain.model
' ─────────────────────────────────────────
package "domain.model" {

    enum Currency {
        USD
        EUR
        TL
    }

    enum TransactionType {
        DEPOSIT
        WITHDRAWAL
        TRANSFER_OUT
        TRANSFER_IN
        INTEREST
    }

    enum AccountType {
        CHECKING
        SAVINGS
        TIME_DEPOSIT
    }

    enum AccountStatus {
        ACTIVE
        FROZEN
        CLOSED
    }

    note right of AccountStatus
      Boundary type for persistence/REST.
      Internally, Account holds an AccountState.
      State machine (terminal = CLOSED):
        ACTIVE  --freeze()--> FROZEN
        FROZEN  --unfreeze()--> ACTIVE
        ACTIVE  --close()--> CLOSED
        FROZEN  --close()--> CLOSED
    end note

    class CustomerId <<record>> {
        + UUID value
        --
        + {static} CustomerId generate()
        + {static} CustomerId of(UUID)
        + {static} CustomerId of(String)
    }

    class AccountId <<record>> {
        + UUID value
        --
        + {static} AccountId generate()
        + {static} AccountId of(UUID)
        + {static} AccountId of(String)
    }

    class TransactionId <<record>> {
        + UUID value
        --
        + {static} TransactionId generate()
        + {static} TransactionId of(UUID)
    }

    class Password <<record>> {
        + String hashedValue
        --
        + {static} Password ofHashed(String)
    }

    class Money <<record>> {
        + BigDecimal amount
        + Currency currency
        --
        + {static} Money of(BigDecimal, Currency)
        + {static} Money of(double, Currency)
        + {static} Money zero(Currency)
        + Money add(Money)
        + Money subtract(Money)
        + Money multiply(BigDecimal)
        + Money negate()
        + boolean isGreaterThanOrEqualTo(Money)
        + boolean isNegative()
        + boolean isZero()
    }

    class Customer <<entity>> {
        - CustomerId id
        - String name
        - String email
        - String role
        - Password currentPassword
        - List<Password> passwordHistory
        --
        + {static} Customer create(String, String, Password)
        + void changePassword(Password)
        + List<Password> getAllPasswordsForReuseCheck()
        + CustomerId getId()
        + String getName()
        + String getEmail()
        + String getRole()
        + Password getCurrentPassword()
        + List<Password> getPasswordHistory()
    }

    abstract class Account <<sealed>> {
        # AccountId id
        # CustomerId ownerId
        # Currency currency
        # Money balance
        # AccountState state
        --
        + {abstract} AccountType type()
        .. operations (overridden per subtype) ..
        + {abstract} Transaction deposit(Money)
        + {abstract} Transaction withdraw(Money)
        + {abstract} Transaction transferOut(Money, Money, String)
        + {final} Transaction transferIn(Money, String)
        .. status transitions (delegate to state) ..
        + {final} void freeze()
        + {final} void unfreeze()
        + {final} void close()
        .. accessors ..
        + AccountStatus getStatus()
        + AccountState getState()
    }

    class CheckingAccount <<entity>> {
        - Money overdraftLimit
        --
        + {static} CheckingAccount open(CustomerId, Currency)
        + {static} CheckingAccount open(CustomerId, Currency, Money)
        + Money getOverdraftLimit()
    }

    class SavingsAccount <<entity>> {
        - BigDecimal annualInterestRate
        - LocalDate lastAccrualDate
        --
        + {static} SavingsAccount open(CustomerId, Currency, BigDecimal)
        + Transaction accrueInterest(YearMonth)
        + BigDecimal getAnnualInterestRate()
        + LocalDate getLastAccrualDate()
    }

    class TimeDepositAccount <<entity>> {
        - Money principal
        - LocalDate openedOn
        - LocalDate maturityDate
        - BigDecimal annualInterestRate
        - boolean matured
        --
        + {static} TimeDepositAccount open(CustomerId, Currency, Money, LocalDate, LocalDate, BigDecimal)
        + Transaction mature(LocalDate)
        + Money getPrincipal()
        + LocalDate getOpenedOn()
        + LocalDate getMaturityDate()
        + BigDecimal getAnnualInterestRate()
        + boolean isMatured()
    }

    note right of CheckingAccount
      Allows balance to go
      negative down to
      -overdraftLimit.
    end note

    note right of SavingsAccount
      Rejects overdraft.
      accrueInterest works on
      ACTIVE or FROZEN, not CLOSED.
    end note

    note right of TimeDepositAccount
      deposit always rejected.
      withdraw rejected until matured.
      mature works on ACTIVE or FROZEN.
    end note

    interface AccountState <<sealed>> {
        + AccountStatus status()
        + AccountState freeze()
        + AccountState unfreeze()
        + AccountState close()
        + void requireOperable()
        + boolean isTerminal()
        + {static} AccountState of(AccountStatus)
    }

    class ActiveState <<state>> {
        + {static} ActiveState INSTANCE
    }

    class FrozenState <<state>> {
        + {static} FrozenState INSTANCE
    }

    class ClosedState <<state>> {
        + {static} ClosedState INSTANCE
    }

    note bottom of AccountState
      State pattern.
      Each implementation owns
      its own valid transitions
      and operability check.
      Stateless singletons.
    end note

    class Transaction <<entity>> {
        - TransactionId id
        - AccountId accountId
        - TransactionType type
        - Money amount
        - LocalDateTime timestamp
        - String description
        --
        + {static} Transaction create(AccountId, TransactionType, Money, String)
        + TransactionId getId()
        + AccountId getAccountId()
        + TransactionType getType()
        + Money getAmount()
        + LocalDateTime getTimestamp()
        + String getDescription()
    }

    Customer    "1" *-right- "1"    CustomerId    : id
    Customer    "1" *-down-  "1"    Password      : currentPassword
    Customer    "1" *-down-  "0..3" Password      : passwordHistory

    Account     "1" *-right- "1"    AccountId     : id
    Account     "1" *-down-  "1"    Money         : balance
    Account     "1" o-right- "1"    CustomerId    : ownerId
    Account     "1" o-right- "1"    Currency
    Account     "1" *-down-  "1"    AccountState  : state
    Account ..> AccountType : type()
    Account ..> AccountStatus : status() (via state)

    Account <|-- CheckingAccount
    Account <|-- SavingsAccount
    Account <|-- TimeDepositAccount

    AccountState <|.. ActiveState
    AccountState <|.. FrozenState
    AccountState <|.. ClosedState

    Transaction "1" *-right- "1"    TransactionId : id
    Transaction "1" *-down-  "1"    Money         : amount
    Transaction "1" o-right- "1"    AccountId     : accountId
    Transaction "1" o-right- "1"    TransactionType
    Money       "1" o-right- "1"    Currency
}

' ─────────────────────────────────────────
' PACKAGE: domain.service
' ─────────────────────────────────────────
package "domain.service" {

    class PasswordValidationService <<service>> {
        + void validate(String rawPassword)
    }

    class TransferDomainService <<service>> {
        + Money calculateFee(Money, boolean, BigDecimal)
    }
}

TransferDomainService ..> Money : "returns"

' ─────────────────────────────────────────
' PACKAGE: domain.port.in  (Use Cases)
' Command records are nested classes shown
' with +-- (inner class) relationship.
' ─────────────────────────────────────────
package "domain.port.in" {

    interface CreateCustomerUseCase {
        + Customer createCustomer(Command)
    }
    class CreateCustomerCommand <<record>> {
        + String name
        + String email
        + String rawPassword
    }
    CreateCustomerUseCase +-- CreateCustomerCommand

    interface DeleteCustomerUseCase {
        + void deleteCustomer(CustomerId)
    }

    interface ListCustomersUseCase {
        + List<Customer> listCustomers()
    }

    interface ChangePasswordUseCase {
        + void changePassword(Command)
    }
    class ChangePasswordCommand <<record>> {
        + CustomerId customerId
        + String rawNewPassword
    }
    ChangePasswordUseCase +-- ChangePasswordCommand

    interface OpenCheckingAccountUseCase {
        + CheckingAccount openChecking(Command)
    }
    class OpenCheckingAccountCommand <<record>> {
        + CustomerId ownerId
        + Currency currency
        + Money overdraftLimit
    }
    OpenCheckingAccountUseCase +-- OpenCheckingAccountCommand

    interface OpenSavingsAccountUseCase {
        + SavingsAccount openSavings(Command)
    }
    class OpenSavingsAccountCommand <<record>> {
        + CustomerId ownerId
        + Currency currency
        + BigDecimal annualInterestRate
    }
    OpenSavingsAccountUseCase +-- OpenSavingsAccountCommand

    interface OpenTimeDepositAccountUseCase {
        + TimeDepositAccount openTimeDeposit(Command)
    }
    class OpenTimeDepositAccountCommand <<record>> {
        + CustomerId ownerId
        + Currency currency
        + Money principal
        + LocalDate maturityDate
        + BigDecimal annualInterestRate
    }
    OpenTimeDepositAccountUseCase +-- OpenTimeDepositAccountCommand

    interface DepositMoneyUseCase {
        + Transaction deposit(Command)
    }
    class DepositMoneyCommand <<record>> {
        + AccountId accountId
        + Money amount
    }
    DepositMoneyUseCase +-- DepositMoneyCommand

    interface WithdrawMoneyUseCase {
        + Transaction withdraw(Command)
    }
    class WithdrawMoneyCommand <<record>> {
        + AccountId accountId
        + Money amount
    }
    WithdrawMoneyUseCase +-- WithdrawMoneyCommand

    interface GetBalanceUseCase {
        + Money getBalance(AccountId)
    }

    interface GetTransactionsUseCase {
        + List<Transaction> getTransactions(AccountId)
    }

    interface ListAccountsUseCase {
        + List<Account> listAccounts(CustomerId)
    }

    interface TransferMoneyUseCase {
        + void transfer(Command)
    }
    class TransferMoneyCommand <<record>> {
        + AccountId sourceAccountId
        + AccountId targetAccountId
        + Money amount
    }
    TransferMoneyUseCase +-- TransferMoneyCommand

    interface SetTransferFeeUseCase {
        + void setTransferFee(Command)
    }
    class SetTransferFeeCommand <<record>> {
        + BigDecimal feePercent
    }
    SetTransferFeeUseCase +-- SetTransferFeeCommand

    interface FreezeAccountUseCase {
        + void freezeAccount(AccountId)
    }

    interface UnfreezeAccountUseCase {
        + void unfreezeAccount(AccountId)
    }

    interface CloseAccountUseCase {
        + void closeAccount(AccountId)
    }

    interface AccrueInterestUseCase {
        + Transaction accrueInterest(Command)
    }
    class AccrueInterestCommand <<record>> {
        + AccountId accountId
        + YearMonth month
    }
    AccrueInterestUseCase +-- AccrueInterestCommand

    interface MatureTimeDepositUseCase {
        + Transaction mature(Command)
    }
    class MatureTimeDepositCommand <<record>> {
        + AccountId accountId
    }
    MatureTimeDepositUseCase +-- MatureTimeDepositCommand
}

' ─────────────────────────────────────────
' PACKAGE: domain.port.out
' ─────────────────────────────────────────
package "domain.port.out" {

    interface CustomerRepositoryPort {
        + Customer save(Customer)
        + Optional<Customer> findById(CustomerId)
        + Optional<Customer> findByEmail(String)
        + List<Customer> findAll()
        + void deleteById(CustomerId)
        + boolean existsById(CustomerId)
    }

    interface AccountRepositoryPort {
        + Account save(Account)
        + Optional<Account> findById(AccountId)
        + List<Account> findByOwnerId(CustomerId)
        + boolean existsById(AccountId)
    }

    interface TransactionRepositoryPort {
        + Transaction save(Transaction)
        + List<Transaction> findByAccountId(AccountId)
    }

    interface PasswordHasherPort {
        + String hash(String rawPassword)
        + boolean matches(String rawPassword, String hashedPassword)
    }

    interface SettingsRepositoryPort {
        + BigDecimal getTransferFeePercent()
        + void setTransferFeePercent(BigDecimal)
    }
}

' ─────────────────────────────────────────
' Cross-package dependencies
' ─────────────────────────────────────────
CreateCustomerUseCase            ..> Customer            : "returns"
ListCustomersUseCase             ..> Customer            : "returns"
DeleteCustomerUseCase            ..> CustomerId          : "uses"
ChangePasswordUseCase            ..> CustomerId          : "uses"
OpenCheckingAccountUseCase       ..> CheckingAccount     : "returns"
OpenSavingsAccountUseCase        ..> SavingsAccount      : "returns"
OpenTimeDepositAccountUseCase    ..> TimeDepositAccount  : "returns"
ListAccountsUseCase              ..> Account             : "returns"
DepositMoneyUseCase              ..> Transaction         : "returns"
WithdrawMoneyUseCase             ..> Transaction         : "returns"
GetBalanceUseCase                ..> Money               : "returns"
GetTransactionsUseCase           ..> Transaction         : "returns"
TransferMoneyUseCase             ..> AccountId           : "uses"
FreezeAccountUseCase             ..> AccountId           : "uses"
UnfreezeAccountUseCase           ..> AccountId           : "uses"
CloseAccountUseCase              ..> AccountId           : "uses"
AccrueInterestUseCase            ..> Transaction         : "returns"
MatureTimeDepositUseCase         ..> Transaction         : "returns"

CustomerRepositoryPort    ..> Customer    : "manages"
AccountRepositoryPort     ..> Account     : "manages"
TransactionRepositoryPort ..> Transaction : "manages"

@enduml
